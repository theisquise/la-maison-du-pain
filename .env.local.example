# ============================================================
# CONFIGURATION STRIPE - PAIEMENTS SÉCURISÉS
# ============================================================
# 1. Créez un compte sur https://stripe.com
# 2. Allez dans Tableau de bord > Développeurs > Clés API
# 3. Copiez vos clés ci-dessous
# 4. Renommez ce fichier en ".env.local"
# ============================================================

# Clé secrète Stripe (commence par sk_live_ ou sk_test_)
STRIPE_SECRET_KEY=sk_test_VOTRE_CLE_SECRETE_ICI

# Clé publique Stripe (commence par pk_live_ ou pk_test_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_VOTRE_CLE_PUBLIQUE_ICI

# Secret webhook Stripe (pour confirmer les paiements)
# Dans Stripe > Développeurs > Webhooks > Ajouter un endpoint
# URL: https://votresite.com/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_SECRET_WEBHOOK_ICI

# URL de votre site (en production, mettez votre vrai domaine)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# ADMINISTRATION - INTERFACE ADMIN SÉCURISÉE
# ============================================================
# Accès à /admin/login avec ce mot de passe
# Choisissez un mot de passe fort en production !
ADMIN_PASSWORD=changez-ce-mot-de-passe

# Clé secrète pour signer les tokens de session admin
# Générez une valeur aléatoire forte (ex: openssl rand -hex 32)
ADMIN_SECRET=changez-cette-cle-secrete-avec-une-valeur-aleatoire-longue
